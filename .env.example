# Database (PostgreSQL)
# Get these from Vercel Postgres, Supabase, or Neon
POSTGRES_PRISMA_URL="postgresql://user:password@host:port/database?schema=public"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:port/database?schema=public"

# Authentication (Clerk)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=

# SMS (Twilio) — Optional. If not set, SMS will be simulated.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
